# ============================================
# FinEasy Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# Spring Profile (dev / prod)
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (prod profile)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fineasydb
DB_USERNAME=fineasy
DB_PASSWORD=fineasy

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (prod profile - generate a secure random string)
JWT_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# KIS (Korea Investment & Securities)
KIS_APPKEY=
KIS_APPSECRET=
KIS_ACCOUNT_NUMBER=
KIS_ENVIRONMENT=prod
DATA_PROVIDER_TYPE=mock

# ECOS (Bank of Korea)
ECOS_API_KEY=

# DART (Financial Supervisory Service)
DART_API_KEY=

# News Collection
NEWS_COLLECTION_ENABLED=false
