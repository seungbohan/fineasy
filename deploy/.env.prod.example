# ============================================
# Production Environment Variables
# Copy this to ~/fineasy/.env and fill in values
# ============================================

# --- Docker Image Settings ---
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_PREFIX=YOUR_GITHUB_USERNAME/YOUR_REPO
IMAGE_TAG=latest

# --- Database ---
DB_NAME=fineasydb
DB_USERNAME=fineasy
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# --- JWT (REQUIRED - minimum 32 characters) ---
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# --- API Keys (leave empty to use mock data) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
KIS_APPKEY=
KIS_APPSECRET=
KIS_ACCOUNT_NUMBER=
KIS_ENVIRONMENT=prod
DATA_PROVIDER_TYPE=mock
ECOS_API_KEY=
FRED_API_KEY=
DART_API_KEY=

# --- Feature Flags ---
NEWS_COLLECTION_ENABLED=false

# --- CORS (set to your domain or * for IP access) ---
CORS_ALLOWED_ORIGINS=*
