# ===========================================
# KIS (Korea Investment & Securities) OpenAPI
# ===========================================
# Get your API keys from: https://apiportal.koreainvestment.com/
KIS_APPKEY=your-appkey
KIS_APPSECRET=your-appsecret
KIS_ACCOUNT_NUMBER=00000000-00

# Environment: prod (real trading) or vts (virtual trading / paper trading)
KIS_ENVIRONMENT=prod

# Data provider type: mock (default) or kis (real KIS API)
DATA_PROVIDER_TYPE=mock

# ===========================================
# ECOS (Bank of Korea Economic Statistics)
# ===========================================
# Get your API key from: https://ecos.bok.or.kr/api/
# Leave empty to use mock macro indicator data
ECOS_API_KEY=

# ===========================================
# FRED (Federal Reserve Economic Data)
# ===========================================
# Get your API key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Leave empty to disable FRED data collection
FRED_API_KEY=

# ===========================================
# DART (Financial Supervisory Service)
# ===========================================
# Get your API key from: https://opendart.fss.or.kr/
# Leave empty to disable DART financial data fetching
DART_API_KEY=

# ===========================================
# OpenAI
# ===========================================
# Get your API key from: https://platform.openai.com/
# Leave empty to use mock AI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REASONING_MODEL=o4-mini

# ===========================================
# Database (PostgreSQL)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fineasydb
DB_USERNAME=fineasy
DB_PASSWORD=fineasy

# ===========================================
# Redis
# ===========================================
# Set to true to enable Redis caching
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# News Collection
# ===========================================
# Set to true to enable RSS news collection and global event classification
NEWS_COLLECTION_ENABLED=false

# ===========================================
# JWT (REQUIRED - must set a strong secret, minimum 256 bits / 32 chars)
# ===========================================
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ===========================================
# CORS (comma-separated allowed origins for production)
# ===========================================
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
